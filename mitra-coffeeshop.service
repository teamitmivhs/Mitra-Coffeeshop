[Unit]
Description=Mitra Coffeeshop web preview
After=network.target

[Service]
Type=simple
WorkingDirectory=/home/it/mitra-coffeeshop
Environment=PATH=/home/it/.bun/bin:/home/it/.nvm/versions/node/v24.16.0/bin:/usr/local/bin:/usr/bin:/bin
ExecStart=/home/it/.bun/bin/bun run preview --port 3001 --host 0.0.0.0
Restart=on-failure
RestartSec=3

[Install]
WantedBy=default.target
